{
  "manifest_version": 3,
  "name": "9Prompt",
  "description": "Save, organize, and reuse AI prompts locally.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_title": "9Prompt",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png"
    }
  },
  "permissions": ["storage"]
}
